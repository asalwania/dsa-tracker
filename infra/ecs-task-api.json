{
  "family": "dsa-tracker-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "<ECS_TASK_EXECUTION_ROLE_ARN>",
  "taskRoleArn": "<ECS_TASK_ROLE_ARN>",
  "containerDefinitions": [
    {
      "name": "dsa-api",
      "image": "<ECR_REGISTRY>/dsa-tracker-api:<TAG>",
      "essential": true,
      "portMappings": [
        {
          "name": "http-api",
          "containerPort": 5000,
          "hostPort": 5000,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        { "name": "NODE_ENV", "valueFrom": "<API_SECRETS_ARN>:NODE_ENV::" },
        { "name": "PORT", "valueFrom": "<API_SECRETS_ARN>:PORT::" },
        { "name": "MONGODB_URI", "valueFrom": "<API_SECRETS_ARN>:MONGODB_URI::" },
        { "name": "REDIS_URL", "valueFrom": "<API_SECRETS_ARN>:REDIS_URL::" },
        { "name": "JWT_ACCESS_SECRET", "valueFrom": "<API_SECRETS_ARN>:JWT_ACCESS_SECRET::" },
        { "name": "JWT_REFRESH_SECRET", "valueFrom": "<API_SECRETS_ARN>:JWT_REFRESH_SECRET::" },
        {
          "name": "JWT_ACCESS_EXPIRES_IN",
          "valueFrom": "<API_SECRETS_ARN>:JWT_ACCESS_EXPIRES_IN::"
        },
        {
          "name": "JWT_REFRESH_EXPIRES_IN",
          "valueFrom": "<API_SECRETS_ARN>:JWT_REFRESH_EXPIRES_IN::"
        },
        { "name": "GOOGLE_CLIENT_ID", "valueFrom": "<API_SECRETS_ARN>:GOOGLE_CLIENT_ID::" },
        {
          "name": "GOOGLE_CLIENT_SECRET",
          "valueFrom": "<API_SECRETS_ARN>:GOOGLE_CLIENT_SECRET::"
        },
        {
          "name": "GOOGLE_CALLBACK_URL",
          "valueFrom": "<API_SECRETS_ARN>:GOOGLE_CALLBACK_URL::"
        },
        { "name": "GITHUB_CLIENT_ID", "valueFrom": "<API_SECRETS_ARN>:GITHUB_CLIENT_ID::" },
        {
          "name": "GITHUB_CLIENT_SECRET",
          "valueFrom": "<API_SECRETS_ARN>:GITHUB_CLIENT_SECRET::"
        },
        {
          "name": "GITHUB_CALLBACK_URL",
          "valueFrom": "<API_SECRETS_ARN>:GITHUB_CALLBACK_URL::"
        },
        { "name": "CLIENT_URL", "valueFrom": "<API_SECRETS_ARN>:CLIENT_URL::" },
        { "name": "COOKIE_DOMAIN", "valueFrom": "<API_SECRETS_ARN>:COOKIE_DOMAIN::" },
        { "name": "AWS_REGION", "valueFrom": "<API_SECRETS_ARN>:AWS_REGION::" },
        { "name": "AWS_ACCESS_KEY_ID", "valueFrom": "<API_SECRETS_ARN>:AWS_ACCESS_KEY_ID::" },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "valueFrom": "<API_SECRETS_ARN>:AWS_SECRET_ACCESS_KEY::"
        },
        { "name": "AWS_S3_BUCKET", "valueFrom": "<API_SECRETS_ARN>:AWS_S3_BUCKET::" },
        { "name": "AWS_SQS_QUEUE_URL", "valueFrom": "<API_SECRETS_ARN>:AWS_SQS_QUEUE_URL::" }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "node -e \"fetch('http://127.0.0.1:5000/api/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/dsa-tracker-api",
          "awslogs-region": "<AWS_REGION>",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
